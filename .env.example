# Neon Database URL (replace with your actual Neon connection string)
DATABASE_URL=postgresql://user:password@host/database

# Base URL for QR codes
NEXT_PUBLIC_BASE_URL=https://fixready.imajin.ai

# Session signing secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Imajin integration
IMAJIN_AUTH_URL=https://jin.imajin.ai
IMAJIN_APP_ID=         # App ID from registry
IMAJIN_APP_DID=        # App DID from registry
IMAJIN_APP_ATTESTATION_ID=  # App's attestation ID for kernel API calls
NEXT_PUBLIC_IMAJIN_AUTH_URL=https://jin.imajin.ai
NEXT_PUBLIC_IMAJIN_APP_ID=
